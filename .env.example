NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server-only. Create this in the OpenAI API dashboard; never expose it with NEXT_PUBLIC_.
# Without this, the AI Art Director returns 503 "not configured".
OPENAI_API_KEY=
# Optional model override. Default is gpt-4o-mini (widely available + cheap).
# Use a reasoning model (e.g. o4-mini) to enable step-by-step reasoning.
OPENAI_ART_DIRECTOR_MODEL=gpt-4o-mini
